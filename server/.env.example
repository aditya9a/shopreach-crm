# MongoDB connection string (get free cluster at https://cloud.mongodb.com)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/shopreach?retryWrites=true&w=majority

# Google Gemini API key (get free at https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Channel Service URL (local dev or deployed URL)
CHANNEL_SERVICE_URL=http://localhost:3001

# Port for this server
PORT=5000

# CRM Server URL (used by channel service for callbacks — set to deployed URL in production)
CRM_SERVER_URL=http://localhost:5000
